<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="700.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.StudentFormController">
   <children>
      <Label layoutX="30.0" layoutY="25.0" text="Student Management Registration" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>

      <GridPane hgap="15.0" layoutX="30.0" layoutY="80.0" prefWidth="640.0" vgap="15.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextField fx:id="txtId" prefHeight="35.0" promptText="Student ID (e.g. S001)" />
            <TextField fx:id="txtName" prefHeight="35.0" promptText="Full Name" GridPane.columnIndex="1" />
            <TextField fx:id="txtEmail" prefHeight="35.0" promptText="Email Address" GridPane.rowIndex="1" />
            <TextField fx:id="txtContact" prefHeight="35.0" promptText="Contact Number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="txtAddress" prefHeight="35.0" promptText="Address" GridPane.columnSpan="2" GridPane.rowIndex="2" />
         </children>
      </GridPane>

      <HBox layoutX="30.0" layoutY="250.0" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #27ae60;" text="Save" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #f39c12;" text="Update" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #e74c3c;" text="Delete" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#btnClearOnAction" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #95a5a6;" text="Clear" textFill="WHITE" />
         </children>
      </HBox>

      <TableView fx:id="tblStudent" layoutX="30.0" layoutY="310.0" prefHeight="260.0" prefWidth="640.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="310.0">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
        <columns>
          <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
          <TableColumn fx:id="colName" prefWidth="130.0" text="Name" />
          <TableColumn fx:id="colEmail" prefWidth="150.0" text="Email" />
          <TableColumn fx:id="colContact" prefWidth="110.0" text="Contact" />
          <TableColumn fx:id="colAddress" prefWidth="168.0" text="Address" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
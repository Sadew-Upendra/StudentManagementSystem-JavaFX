<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.StudentFormController">
   <children>
      <VBox prefHeight="600.0" prefWidth="220.0" styleClass="sidebar">
         <children>
            <Label text="STUDENT MS" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="50.0" left="20.0" top="30.0" />
               </VBox.margin>
            </Label>
            <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #34495e;" text="Dashboard" textFill="WHITE" />
            <Button layoutX="10.0" layoutY="125.0" mnemonicParsing="false" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #2980b9;" text="Manage Students" textFill="WHITE" />
         </children>
      </VBox>

      <AnchorPane layoutX="220.0" prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #f5f6fa;">
         <children>
            <Label layoutX="30.0" layoutY="25.0" text="Student Management Registration" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>

            <GridPane hgap="15.0" layoutX="30.0" layoutY="70.0" prefHeight="150.0" prefWidth="620.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <TextField fx:id="txtId" promptText="Student ID (e.g. S001)" />
                  <TextField fx:id="txtName" promptText="Full Name" GridPane.columnIndex="1" />
                  <TextField fx:id="txtEmail" promptText="Email Address" GridPane.rowIndex="1" />
                  <TextField fx:id="txtContact" promptText="Contact Number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <TextField fx:id="txtAddress" promptText="Address" GridPane.columnSpan="2" GridPane.rowIndex="2" />
               </children>
            </GridPane>

            <HBox layoutX="30.0" layoutY="235.0" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#btnSaveOnAction" prefWidth="100.0" styleClass="btn-save" text="Save" />
                  <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefWidth="100.0" style="-fx-background-color: #f39c12;" text="Update" textFill="WHITE" />
                  <Button layoutX="125.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefWidth="100.0" styleClass="btn-delete" text="Delete" />
                  <Button layoutX="240.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnClearOnAction" prefWidth="100.0" style="-fx-background-color: #95a5a6;" text="Clear" textFill="WHITE" />
               </children>
            </HBox>

            <TableView fx:id="tblStudent" layoutX="30.0" layoutY="285.0" prefHeight="285.0" prefWidth="620.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="120.0" text="Name" />
                <TableColumn fx:id="colEmail" prefWidth="140.0" text="Email" />
                <TableColumn fx:id="colContact" prefWidth="110.0" text="Contact" />
                <TableColumn fx:id="colAddress" prefWidth="173.0" text="Address" />
              </columns>
            </TableView>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.MainLayoutController">
   <left>
      <VBox prefWidth="240.0" spacing="10.0" styleClass="sidebar">
         <children>
            <Label text="SMS PRO" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="26.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="40.0" left="25.0" top="30.0" />
               </VBox.margin>
            </Label>
            
            <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#navigateToDashboard" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0 0 0 25;" text="Dashboard">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
            
            <Button fx:id="btnRegistration" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#navigateToRegistration" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0 0 0 25;" text="Register Student">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>

            <Button fx:id="btnReports" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#navigateToReports" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 0 0 0 25;" text="Generate Reports">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>

            <Region VBox.vgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#exitApp" prefHeight="45.0" prefWidth="240.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 0;" text="Logout">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="contentContext" style="-fx-background-color: #f5f6fa;" />
   </center>
</BorderPane>

